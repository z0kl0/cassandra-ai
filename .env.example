# ============================================================
#  CASSANDRA - configuration (local-first)
#  Copy to .env and fill in. Never commit your real .env.
# ============================================================

# --- SEC EDGAR ---
# REQUIRED by SEC: a descriptive User-Agent with a contact email.
# Requests without it are blocked. Format: "Name email@example.com"
SEC_USER_AGENT=Your Name your.email@example.com

# --- Local LLM (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# Keep the model resident in RAM between calls (avoids reload latency on CPU).
OLLAMA_KEEP_ALIVE=-1

# --- Vector store (embedded, local file path) ---
CHROMA_PATH=./data/chroma

# --- Local cache for fetched SEC fundamentals ---
SEC_CACHE_PATH=./data/sec_cache

# --- Logging ---
LOG_LEVEL=INFO

# --- Optional voice "Interrogation Mode" (stretch). Leave false for the core app. ---
ENABLE_VOICE=false
# Local TTS engine when ENABLE_VOICE=true: piper (local) | edge (online fallback)
TTS_ENGINE=piper
# faster-whisper model size (CPU): tiny | base | small  (larger = slower)
WHISPER_MODEL=base

# --- Committee-debate narration voices (Piper) ---
# Put the .onnx (+ matching .onnx.json) files in voices/ and point these at them. When all three
# exist, the debate's "Narrate aloud" toggle activates (plays in your browser, so it works over a
# Tailscale/remote view). Audio clips are cached under data/audio_cache/.
PIPER_VOICE_CASSANDRA=voices/en_US-libritts_r-medium.onnx
PIPER_VOICE_MICHAEL=voices/en_US-joe-medium.onnx
PIPER_VOICE_CIO=voices/en_US-norman-medium.onnx
# libritts_r is multi-speaker (904 voices) — pick the speaker id for Cassandra (joe/norman are single-speaker).
PIPER_SPEAKER_CASSANDRA=0
# Optional: cache dir for synthesized narration clips
AUDIO_CACHE_PATH=./data/audio_cache
